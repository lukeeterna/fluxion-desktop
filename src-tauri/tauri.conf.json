{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fluxion",
  "version": "1.0.1",
  "identifier": "com.fluxion.desktop",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "fullscreen": false,
        "height": 800,
        "resizable": true,
        "title": "Fluxion",
        "width": 1200
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "Business",
    "externalBin": [
      "binaries/voice-agent"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "../entitlements.plist",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null,
      "minimumSystemVersion": "10.15"
    },
    "targets": ["dmg", "app", "nsis"],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "wix": {
        "language": "it-IT"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/lukeeterna/fluxion-desktop/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "RWRqEGaKs2CWiWHG+mWdKMQOdSy15M2kAbmdX2vup9lv765450pUWtNA"
    }
  }
}
