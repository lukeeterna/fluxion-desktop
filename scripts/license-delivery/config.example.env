# FLUXION License Delivery Server — Configurazione
# Copia questo file in config.env e compila i valori

# ── LemonSqueezy Store ─────────────────────────────────────────────────────────
# Store: https://fluxion.lemonsqueezy.com
# Checkout links (NON cambiano mai, salvati qui per riferimento):
#   Base   €497:   https://fluxion.lemonsqueezy.com/checkout/buy/c73ec6bb-24c2-4214-a456-320c67056bd3
#   Pro    €897:   https://fluxion.lemonsqueezy.com/checkout/buy/14806a0d-ac44-44af-a051-8fe8c559d702
#   Clinic €1.497: https://fluxion.lemonsqueezy.com/checkout/buy/e3864cc0-937b-486d-b412-a1bebcfe0023

# Webhook signing secret
# Trovalo su: LemonSqueezy Dashboard → Settings → Webhooks → [tuo webhook] → Signing Secret
LS_WEBHOOK_SECRET=cambia_con_il_tuo_secret

# SMTP per invio email istruzioni al cliente
# Per Gmail: crea una "App Password" su https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=la_tua_email@gmail.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx
SMTP_FROM_NAME=FLUXION

# Percorso al tool CLI fluxion-keygen (compilato su iMac)
FLUXION_KEYGEN_PATH=/Users/gianlucadistasi/fluxion-keygen

# Percorso al keypair Ed25519 (NON mettere in git!)
KEYPAIR_PATH=/Users/gianlucadistasi/fluxion-keypair.json

# URL base pubblico del server (dopo Cloudflare Tunnel)
# Esempio: https://fluxion-activate.tuodominio.com
ACTIVATE_URL_BASE=https://fluxion-activate.tuodominio.com

# Porta del server (default: 3010)
PORT=3010

# Percorso database SQLite ordini (default: orders.db nella stessa cartella)
# DB_PATH=/custom/path/orders.db

# Max tentativi attivazione per order_id (default: 3)
# MAX_ACTIVATE_TRIES=3
